manifest {
    name = 'nf-clingen'
    author = 'GitHub Copilot'
    homePage = 'https://nextflow.io'
    description = 'Dynamic multi-omic router for clinical diagnostics, genealogy, and low-I/O production sequencing workflows.'
    mainScript = 'main.nf'
    version = '0.2.0'
}

// ── Host RAM auto-detection ──────────────────────────────────────────────────
// Total physical memory is read once at config parse time so every memory
// directive can scale to the actual host rather than being hard-coded.
// A reserve is subtracted to leave headroom for the OS, JVM, Docker daemon,
// and any other co-running processes.  Falls back to 64 GB if the MXBean
// interface is unavailable on the current JRE.
def _totalRamGb = {
    try {
        def osBean = (com.sun.management.OperatingSystemMXBean)(java.lang.management.ManagementFactory.getOperatingSystemMXBean())
        return (int)(osBean.totalPhysicalMemorySize / 1073741824L)
    } catch (ignored) {
        return 64
    }
}()
// Reserve the larger of 16 GB or 5 % of total RAM for OS and co-processes.
def _reserveGb = Math.max(16, (int)(_totalRamGb * 0.05))
// _ramGb is the usable budget exposed as params.max_ram_gb below.
def _ramGb = Math.max(8, _totalRamGb - _reserveGb)

// ── YAML Config Loading ──────────────────────────────────────────────────────
// Optional: Load user parameters from params.yaml if it exists
// YAML parameters override defaults but are overridden by CLI flags
def _loadYamlParams() {
    def knownKeys = [
        'reads','samplesheet','reference','outdir','scratch_dir',
        'skip_qc','aligner','preprocess','caller','workflow',
        'clinvar_vcf','gnomad_vcf','input_vcf','input_vcf_tbi','input_sample_id','max_report_variants','patient_phenotype','phenotype_gene_map',
        'max_cpus','max_ram_gb','max_forks',
        'deepvariant_cpus','deepvariant_memory','deepvariant_time',
        'vqsr_snp_resource','vqsr_omni_resource','vqsr_indel_resource','vqsr_1kg_resource','vqsr_dbsnp_resource',
        'eagle2_genetic_map','beagle_ref_panel','beagle_genetic_map','beagle_jar',
        'execution_mode','aws_region','aws_batch_queue','aws_workdir',
        'help','validate_only'
    ] as Set
    def yamlFile = new File("${projectDir}/params.yaml")
    if( !yamlFile.exists() ) {
        return [:]
    }
    try {
        def parsed = [:]
        yamlFile.eachLine { rawLine ->
            def line = rawLine.trim()
            if( !line || line.startsWith('#') ) {
                return
            }
            def parts = line.split(':', 2)
            if( parts.size() != 2 ) {
                return
            }
            def key = parts[0].trim()
            if( !knownKeys.contains(key) ) {
                System.err.println("Warning: Unknown key in params.yaml ignored: ${key}")
                return
            }
            def value = parts[1].trim()
            if( value.contains(' #') ) {
                value = value.split(/\s+#/, 2)[0].trim()
            }
            if( (value.startsWith('"') && value.endsWith('"')) || (value.startsWith('\'') && value.endsWith('\'')) ) {
                parsed[key] = value.substring(1, value.length() - 1)
                return
            }
            def lower = value.toLowerCase()
            if( lower in ['null', '~', 'none'] ) {
                parsed[key] = null
            }
            else if( lower == 'true' ) {
                parsed[key] = true
            }
            else if( lower == 'false' ) {
                parsed[key] = false
            }
            else if( value ==~ /^[-+]?\d+$/ ) {
                parsed[key] = value.toInteger()
            }
            else if( value ==~ /^[-+]?\d*\.\d+$/ ) {
                parsed[key] = value.toDouble()
            }
            else {
                parsed[key] = value
            }
        }
        return parsed
    } catch (Exception e) {
        System.err.println("Warning: Could not parse params.yaml: ${e.message}")
        return [:]
    }
}
def _yamlParams = _loadYamlParams()

params {
    reads = "${projectDir}/data/*_R{1,2}.fastq.gz"
    samplesheet = null
    input_vcf = null
    input_vcf_tbi = null
    input_sample_id = null
    reference = "${projectDir}/data/GRCh38.fasta"
    outdir = "${projectDir}/results"
    skip_qc = false
    aligner = 'minimap2'
    preprocess = 'samtools'
    caller = 'haplotypecaller'
    workflow = 'clinical'
    clinvar_vcf = null
    gnomad_vcf = null
    max_report_variants = 25
    patient_phenotype = null
    phenotype_gene_map = "${projectDir}/data/phenotype_gene_map.tsv"
    report_mode = 'auto'  // 'clinical' | 'phenotype' | 'combined' | 'auto' (auto: phenotype if --patient_phenotype, else clinical)
    help = false
    validate_only = false
    // VQSR training resources (used when caller = haplotypecaller and VQSR is enabled)
    vqsr_snp_resource = null
    vqsr_omni_resource = null
    vqsr_indel_resource = null
    vqsr_1kg_resource = null
    vqsr_dbsnp_resource = null
    // Genealogy workflow resources
    // Required when --workflow genealogy:
    //   eagle2_genetic_map — path to Eagle2 genetic map directory (contains genetic_map_hg38_withX.txt.gz)
    //   beagle_ref_panel   — directory of per-chromosome reference panel VCFs (*.chr{N}.vcf.gz)
    // Optional:
    //   beagle_genetic_map — directory of per-chromosome Beagle genetic maps (*.chr{N}.map.gz)
    //   beagle_jar         — path to beagle.*.jar (falls back to container /opt/beagle/beagle.jar)
    eagle2_genetic_map = null
    beagle_ref_panel   = null
    beagle_genetic_map = null
    beagle_jar         = null

    // Optional dedicated work directory on fast scratch storage (for example 7TB NVMe)
    scratch_dir = null
    // Auto-cap local executor at host CPUs minus 2 by default; override with --max_cpus.
    max_cpus = Math.max(1, Runtime.runtime.availableProcessors() - 2)
    // Usable host RAM budget in GB (total minus OS reserve). Override with --max_ram_gb.
    // All per-process memory directives scale relative to this value automatically.
    max_ram_gb = _ramGb
    // Optional overrides for DeepVariant resources.
    deepvariant_cpus = Math.min(48, Math.max(4, Runtime.runtime.availableProcessors() - 2))
    // DeepVariant gets 40 % of the RAM budget (clamped 32–256 GB); override with --deepvariant_memory.
    deepvariant_memory = Math.max(32, Math.min(256, (int)(_ramGb * 0.40))).GB
    deepvariant_time = 24.h
    // Concurrency cap for adaptive_local profile.
    max_forks = Math.max(2, Math.min(8, (Runtime.runtime.availableProcessors() - 2).intdiv(8)))

    // Execution mode:
    // - local: uses adaptive/aggressive local profiles and host auto-detection
    // - aws:   uses AWS Batch profile settings (S3 workdir + Batch queue)
    execution_mode = 'local'

    // AWS profile defaults (used when -profile awsbatch is selected)
    aws_region = 'us-east-1'
    aws_batch_queue = 'nf-clingen-batch-queue'
    aws_workdir = null
}

// Merge any parameters loaded from params.yaml (user YAML overrides defaults, CLI flags override both)
params = params + _yamlParams

// Route working files based on execution mode.
// - local: optional scratch path
// - aws:   required S3 workdir configured via --aws_workdir or profile default
workDir = params.execution_mode == 'aws'
    ? (params.aws_workdir ?: null)
    : (params.scratch_dir ? "${params.scratch_dir}/nf-clingen-work" : null)

process {
    executor = 'local'
    cache = 'lenient'
    errorStrategy = 'terminate'
    maxRetries = 1
    stageInMode = 'copy'
    stageOutMode = 'copy'
    scratch = true

    withName: BUILD_FASTA_INDEX {
        container = 'quay.io/biocontainers/samtools:1.20--h50ea8bc_0'
        cpus = 2
        memory = Math.max(2, Math.min(8,   (int)(params.max_ram_gb * 0.016))).GB
        time = 2.h
    }

    withName: BUILD_SEQUENCE_DICTIONARY {
        container = 'broadinstitute/gatk:4.6.1.0'
        cpus = 2
        memory = Math.max(2, Math.min(8,   (int)(params.max_ram_gb * 0.016))).GB
        time = 2.h
    }

    withName: BUILD_BWAMEM2_INDEX {
        container = 'quay.io/biocontainers/bwa-mem2:2.2.1--h6a68c12_6'
        cpus = 8
        memory = Math.max(8,  Math.min(64,  (int)(params.max_ram_gb * 0.065))).GB
        time = 8.h
    }

    withName: RUN_FASTQC {
        container = 'quay.io/biocontainers/fastqc:0.12.1--hdfd78af_0'
        cpus = 2
        memory = Math.max(2, Math.min(8,   (int)(params.max_ram_gb * 0.008))).GB
        time = 2.h
    }

    withName: RUN_FASTP {
        container = 'quay.io/biocontainers/fastp:0.23.4--hadf994f_2'
        cpus = 4
        memory = Math.max(2, Math.min(16,  (int)(params.max_ram_gb * 0.016))).GB
        time = 4.h
    }

    withName: ALIGN_MINIMAP2 {
        container = 'quay.io/biocontainers/minimap2:2.28--he4a0461_3'
        cpus = 8
        memory = Math.max(8,  Math.min(64,  (int)(params.max_ram_gb * 0.060))).GB
        time = 12.h
    }

    withName: ALIGN_BWAMEM2 {
        container = 'quay.io/biocontainers/bwa-mem2:2.2.1--h6a68c12_6'
        cpus = 8
        memory = Math.max(8,  Math.min(64,  (int)(params.max_ram_gb * 0.065))).GB
        time = 12.h
    }

    withName: RUN_SAMTOOLS {
        container = 'quay.io/biocontainers/samtools:1.20--h50ea8bc_0'
        cpus = 6
        memory = Math.max(4,  Math.min(32,  (int)(params.max_ram_gb * 0.040))).GB
        time = 8.h
    }

    withName: RUN_ELPREP {
        container = 'ghcr.io/exascience/elprep:5.1.3'
        cpus = 8
        memory = Math.max(16, Math.min(128, (int)(params.max_ram_gb * 0.130))).GB
        time = 8.h
    }

    withName: INDEX_BAM {
        container = 'quay.io/biocontainers/samtools:1.20--h50ea8bc_0'
        cpus = 2
        memory = Math.max(2, Math.min(8,   (int)(params.max_ram_gb * 0.010))).GB
        time = 2.h
    }

    withName: CALL_GATK {
        container = 'broadinstitute/gatk:4.6.1.0'
        cpus = 8
        memory = Math.max(16, Math.min(128, (int)(params.max_ram_gb * 0.130))).GB
        time = 24.h
    }

    withName: CALL_DEEPVARIANT {
        container = 'google/deepvariant:1.6.1'
        cpus = params.deepvariant_cpus as int
        memory = params.deepvariant_memory
        time = params.deepvariant_time
    }

    withName: INDEX_CLINVAR_RESOURCE {
        container = 'quay.io/biocontainers/bcftools:1.20--h8b25389_0'
        cpus = 2
        memory = Math.max(2, Math.min(8,   (int)(params.max_ram_gb * 0.010))).GB
        time = 2.h
    }

    withName: RUN_CLINICAL_ANNOTATION {
        container = 'quay.io/biocontainers/bcftools:1.20--h8b25389_0'
        cpus = 2
        memory = Math.max(2, Math.min(16,  (int)(params.max_ram_gb * 0.016))).GB
        time = 4.h
    }

    withName: RUN_CLINVAR_ANNOTATION {
        container = 'quay.io/biocontainers/bcftools:1.20--h8b25389_0'
        cpus = 4
        memory = Math.max(4, Math.min(32,  (int)(params.max_ram_gb * 0.040))).GB
        time = 4.h
    }

    withName: INDEX_GNOMAD_RESOURCE {
        container = 'quay.io/biocontainers/bcftools:1.20--h8b25389_0'
        cpus = 2
        memory = Math.max(2, Math.min(8,   (int)(params.max_ram_gb * 0.010))).GB
        time = 2.h
    }

    withName: RUN_GNOMAD_ANNOTATION {
        container = 'quay.io/biocontainers/bcftools:1.20--h8b25389_0'
        cpus = 4
        memory = Math.max(4, Math.min(32,  (int)(params.max_ram_gb * 0.040))).GB
        time = 4.h
    }

    withName: BUILD_CLINICAL_REPORT {
        container = 'python:3.11'
        cpus = 2
        memory = Math.max(4, Math.min(16,  (int)(params.max_ram_gb * 0.020))).GB
        time = 2.h
    }

    withName: 'PHASE_EAGLE2' {
        container = 'indapa/indapa-eagle:latest'
        cpus = Math.min(16, Math.max(4, (int)(params.max_cpus * 0.25)))
        memory = Math.max(8, Math.min(64, (int)(params.max_ram_gb * 0.10))).GB
        time = 12.h
    }

    withName: 'IMPUTE_BEAGLE' {
        container = 'quay.io/biocontainers/beagle:5.4_22Jul22.46e--hdfd78af_0'
        cpus = Math.min(16, Math.max(4, (int)(params.max_cpus * 0.25)))
        memory = Math.max(16, Math.min(128, (int)(params.max_ram_gb * 0.20))).GB
        time = 24.h
    }

    withName: 'BUILD_GENEALOGY_MANIFEST' {
        container = 'quay.io/biocontainers/bcftools:1.20--h8b25389_0'
        cpus = 1
        memory = 2.GB
        time = 30.min
    }

    withName: 'CONCAT_IMPUTED' {
        container = 'quay.io/biocontainers/bcftools:1.20--h8b25389_0'
        cpus = 2
        memory = Math.max(4, Math.min(16, (int)(params.max_ram_gb * 0.016))).GB
        time = 2.h
    }
}

docker.enabled = false
singularity.enabled = false
apptainer.enabled = false

profiles {
    test {
        params.reads = "${projectDir}/data/test_sample*_R{1,2}.fastq.gz"
        params.reference = "${projectDir}/data/test_ref.fa"
        params.outdir = "${projectDir}/results/test"
        params.skip_qc = true
        process.executor = 'local'
        process.maxForks = 2
    }

    docker {
        docker.enabled = true
        singularity.enabled = false
        apptainer.enabled = false
    }

    // Hardware-adaptive profile for local execution with interactive headroom.
    adaptive_local {
        process.executor = 'local'
        process.maxForks = params.max_forks as int
        executor.queueSize = ((params.max_forks as int) * 2) as int
        executor.cpus = params.max_cpus as int
    }

    // Higher-throughput local profile for large multi-core / high-memory hosts.
    // Memory for all steps is already auto-scaled to the host in the base process block.
    // This profile pushes concurrency higher and gives DeepVariant 50 % of the RAM budget
    // (vs 40 % default) for even faster variant calling on memory-rich machines.
    aggressive_local {
        params.max_forks = Math.max(4, Math.min(16, (params.max_cpus as int).intdiv(4)))
        params.deepvariant_cpus = Math.min(48, params.max_cpus as int)
        // 50 % of usable RAM for DeepVariant, clamped 64-256 GB; override with --deepvariant_memory.
        params.deepvariant_memory = Math.max(64, Math.min(256, (int)(params.max_ram_gb * 0.50))).GB
        params.deepvariant_time = 48.h

        process.executor = 'local'
        process.maxForks = params.max_forks as int
        executor.queueSize = ((params.max_forks as int) * 4) as int
        executor.cpus = params.max_cpus as int
    }

    singularity {
        docker.enabled = false
        singularity.enabled = true
        apptainer.enabled = false
        singularity.autoMounts = true
    }

    apptainer {
        docker.enabled = false
        singularity.enabled = false
        apptainer.enabled = true
        apptainer.autoMounts = true
    }

    // AWS Batch profile: keeps user-facing pipeline params unchanged while
    // switching infrastructure execution to managed cloud resources.
    awsbatch {
        params.execution_mode = 'aws'

        docker.enabled = true
        singularity.enabled = false
        apptainer.enabled = false

        process.executor = 'awsbatch'
        process.queue = params.aws_batch_queue

        aws.region = params.aws_region
        workDir = params.aws_workdir ?: null
    }
}

timeline {
    enabled = true
    file = "${params.outdir}/pipeline_info/timeline.html"
    overwrite = true
}

report {
    enabled = true
    file = "${params.outdir}/pipeline_info/report.html"
    overwrite = true
}

trace {
    enabled = true
    overwrite = true
    file = "${params.outdir}/pipeline_info/trace.txt"
}

dag {
    enabled = true
    overwrite = true
    file = "${params.outdir}/pipeline_info/dag.svg"
}

cleanup = false

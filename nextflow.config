manifest {
    name = 'nf-prism'
    author = 'GitHub Copilot'
    homePage = 'https://nextflow.io'
    description = 'Dynamic multi-omic router for clinical diagnostics, genealogy, and low-I/O production sequencing workflows.'
    mainScript = 'main.nf'
    version = '0.2.0'
}

params {
    reads = "${projectDir}/data/*_R{1,2}.fastq.gz"
    reference = "${projectDir}/data/GRCh38.fasta"
    outdir = "${projectDir}/results"
    skip_qc = false
    aligner = 'minimap2'
    preprocess = 'samtools'
    caller = 'haplotypecaller'
    workflow = 'clinical'
    clinvar_vcf = null
    max_report_variants = 25
    patient_phenotype = null
    phenotype_gene_map = "${projectDir}/data/phenotype_gene_map.tsv"
    help = false
    validate_only = false
}

process {
    executor = 'local'
    cache = 'lenient'
    errorStrategy = 'terminate'
    maxRetries = 1
    stageInMode = 'copy'
    stageOutMode = 'copy'
    scratch = true

    withName: BUILD_FASTA_INDEX {
        container = 'quay.io/biocontainers/samtools:1.20--h50ea8bc_0'
        cpus = 2
        memory = '4 GB'
        time = '2h'
    }

    withName: BUILD_SEQUENCE_DICTIONARY {
        container = 'broadinstitute/gatk:4.6.1.0'
        cpus = 2
        memory = '4 GB'
        time = '2h'
    }

    withName: BUILD_BWAMEM2_INDEX {
        container = 'quay.io/biocontainers/bwa-mem2:2.2.1--h6a68c12_6'
        cpus = 8
        memory = '24 GB'
        time = '8h'
    }

    withName: RUN_FASTQC {
        container = 'quay.io/biocontainers/fastqc:0.12.1--hdfd78af_0'
        cpus = 2
        memory = '2 GB'
        time = '2h'
    }

    withName: RUN_FASTP {
        container = 'quay.io/biocontainers/fastp:0.23.4--hadf994f_2'
        cpus = 4
        memory = '4 GB'
        time = '4h'
    }

    withName: ALIGN_MINIMAP2 {
        container = 'quay.io/biocontainers/minimap2:2.28--he4a0461_3'
        cpus = 8
        memory = '16 GB'
        time = '12h'
    }

    withName: ALIGN_BWAMEM2 {
        container = 'quay.io/biocontainers/bwa-mem2:2.2.1--h6a68c12_6'
        cpus = 8
        memory = '24 GB'
        time = '12h'
    }

    withName: RUN_SAMTOOLS {
        container = 'quay.io/biocontainers/samtools:1.20--h50ea8bc_0'
        cpus = 6
        memory = '12 GB'
        time = '8h'
    }

    withName: RUN_ELPREP {
        container = 'ghcr.io/exascience/elprep:5.1.3'
        cpus = 8
        memory = '48 GB'
        time = '8h'
    }

    withName: INDEX_BAM {
        container = 'quay.io/biocontainers/samtools:1.20--h50ea8bc_0'
        cpus = 2
        memory = '4 GB'
        time = '2h'
    }

    withName: CALL_GATK {
        container = 'broadinstitute/gatk:4.6.1.0'
        cpus = 8
        memory = '32 GB'
        time = '24h'
    }

    withName: CALL_DEEPVARIANT {
        container = 'google/deepvariant:1.6.1'
        cpus = 16
        memory = '48 GB'
        time = '24h'
    }

    withName: INDEX_CLINVAR_RESOURCE {
        container = 'quay.io/biocontainers/bcftools:1.20--h8b25389_0'
        cpus = 2
        memory = '4 GB'
        time = '2h'
    }

    withName: RUN_CLINICAL_ANNOTATION {
        container = 'quay.io/biocontainers/bcftools:1.20--h8b25389_0'
        cpus = 2
        memory = '4 GB'
        time = '4h'
    }

    withName: RUN_CLINVAR_ANNOTATION {
        container = 'quay.io/biocontainers/bcftools:1.20--h8b25389_0'
        cpus = 2
        memory = '4 GB'
        time = '4h'
    }

    withName: BUILD_CLINICAL_REPORT {
        container = 'ghcr.io/kozea/weasyprint:61.2'
        cpus = 2
        memory = '6 GB'
        time = '2h'
    }

    withName: RUN_GENEALOGY_STACK {
        container = 'eclipse-temurin:17-jre'
        cpus = 4
        memory = '8 GB'
        time = '8h'
    }
}

docker.enabled = false
singularity.enabled = false
apptainer.enabled = false

profiles {
    test {
        params.reads = "${projectDir}/data/test_sample*_R{1,2}.fastq.gz"
        params.reference = "${projectDir}/data/test_ref.fa"
        params.outdir = "${projectDir}/results/test"
        params.skip_qc = true
        process.executor = 'local'
        process.maxForks = 2
    }

    docker {
        docker.enabled = true
        singularity.enabled = false
        apptainer.enabled = false
    }

    singularity {
        docker.enabled = false
        singularity.enabled = true
        apptainer.enabled = false
        singularity.autoMounts = true
    }

    apptainer {
        docker.enabled = false
        singularity.enabled = false
        apptainer.enabled = true
        apptainer.autoMounts = true
    }
}

timeline {
    enabled = true
    file = "${params.outdir}/pipeline_info/timeline.html"
}

report {
    enabled = true
    file = "${params.outdir}/pipeline_info/report.html"
}

trace {
    enabled = true
    file = "${params.outdir}/pipeline_info/trace.txt"
}

dag {
    enabled = true
    file = "${params.outdir}/pipeline_info/dag.svg"
}

cleanup = true

validation {
    failUnrecognisedParams = true
}